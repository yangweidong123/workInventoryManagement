<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.InventoryOutMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.InventoryOut">
        <id column="id" property="id"/>
        <result column="inventory_id" property="inventoryId"/>
        <result column="style_no" property="styleNo"/>
        <result column="name" property="name"/>
        <result column="quantity" property="quantity"/>
        <result column="price" property="price"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="out_time" property="outTime"/>
        <result column="operator" property="operator"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectByDateRange" resultMap="BaseResultMap">
        SELECT id, inventory_id, style_no, name, quantity, price, total_amount, out_time, operator, remark
        FROM inventory_out
        <where>
            <if test="startTime != null">
                AND out_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND out_time &lt; #{endTime}
            </if>
        </where>
        ORDER BY out_time DESC
    </select>

</mapper>
