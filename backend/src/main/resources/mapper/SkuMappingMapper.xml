<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.SkuMappingMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.SkuMapping">
        <id column="id" property="id"/>
        <result column="inventory_id" property="inventoryId"/>
        <result column="platform" property="platform"/>
        <result column="platform_sku" property="platformSku"/>
        <result column="platform_product_id" property="platformProductId"/>
        <result column="last_sync_quantity" property="lastSyncQuantity"/>
        <result column="last_sync_time" property="lastSyncTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByPlatformAndSku" resultMap="BaseResultMap">
        SELECT * FROM sku_mapping WHERE platform = #{platform} AND platform_sku = #{platformSku}
    </select>

    <select id="selectByInventoryId" resultMap="BaseResultMap">
        SELECT * FROM sku_mapping WHERE inventory_id = #{inventoryId}
    </select>

    <select id="selectByPlatform" resultMap="BaseResultMap">
        SELECT * FROM sku_mapping WHERE platform = #{platform}
    </select>

</mapper>
