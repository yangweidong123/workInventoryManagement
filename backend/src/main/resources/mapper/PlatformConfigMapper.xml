<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.PlatformConfigMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.PlatformConfig">
        <id column="id" property="id"/>
        <result column="platform" property="platform"/>
        <result column="shop_name" property="shopName"/>
        <result column="app_key" property="appKey"/>
        <result column="app_secret" property="appSecret"/>
        <result column="access_token" property="accessToken"/>
        <result column="refresh_token" property="refreshToken"/>
        <result column="token_expire_time" property="tokenExpireTime"/>
        <result column="webhook_url" property="webhookUrl"/>
        <result column="enabled" property="enabled"/>
        <result column="sync_mode" property="syncMode"/>
        <result column="sync_interval" property="syncInterval"/>
        <result column="last_sync_time" property="lastSyncTime"/>
        <result column="last_heartbeat" property="lastHeartbeat"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByPlatform" resultMap="BaseResultMap">
        SELECT * FROM platform_config WHERE platform = #{platform}
    </select>

</mapper>
