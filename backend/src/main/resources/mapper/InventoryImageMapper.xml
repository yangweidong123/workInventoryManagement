<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.InventoryImageMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.InventoryImage">
        <id column="id" property="id"/>
        <result column="inventory_id" property="inventoryId"/>
        <result column="image_url" property="imageUrl"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByInventoryId" resultMap="BaseResultMap">
        SELECT id, inventory_id, image_url, sort, create_time
        FROM inventory_image
        WHERE inventory_id = #{inventoryId}
        ORDER BY sort ASC
    </select>

    <delete id="deleteByInventoryId">
        DELETE FROM inventory_image WHERE inventory_id = #{inventoryId}
    </delete>

</mapper>
