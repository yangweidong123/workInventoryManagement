<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.PlatformOrderMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.PlatformOrder">
        <id column="id" property="id"/>
        <result column="platform" property="platform"/>
        <result column="order_id" property="orderId"/>
        <result column="sku_mapping_id" property="skuMappingId"/>
        <result column="order_type" property="orderType"/>
        <result column="quantity" property="quantity"/>
        <result column="amount" property="amount"/>
        <result column="status" property="status"/>
        <result column="paid_time" property="paidTime"/>
        <result column="refund_time" property="refundTime"/>
        <result column="processed" property="processed"/>
        <result column="raw_data" property="rawData"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByPlatformAndOrderId" resultMap="BaseResultMap">
        SELECT * FROM platform_order WHERE platform = #{platform} AND order_id = #{orderId}
    </select>

</mapper>
