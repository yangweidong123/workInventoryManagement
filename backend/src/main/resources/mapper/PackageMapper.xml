<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.PackageMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.Package">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="total_price" property="totalPrice"/>
        <result column="cost_price" property="costPrice"/>
        <result column="profit_rate" property="profitRate"/>
        <result column="sold_quantity" property="soldQuantity"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="DetailResultMap" type="com.inventory.dto.PackageDTO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="total_price" property="totalPrice"/>
        <result column="cost_price" property="costPrice"/>
        <result column="profit_rate" property="profitRate"/>
        <result column="sold_quantity" property="soldQuantity"/>
    </resultMap>

    <select id="selectPageList" resultMap="DetailResultMap">
        SELECT
            id,
            name,
            total_price,
            cost_price,
            profit_rate,
            sold_quantity
        FROM package
        <where>
            <if test="query.name != null and query.name != ''">
                AND name LIKE CONCAT('%', #{query.name}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectDetailById" resultMap="DetailResultMap">
        SELECT
            id,
            name,
            total_price,
            cost_price,
            profit_rate,
            sold_quantity
        FROM package
        WHERE id = #{id}
    </select>

</mapper>
